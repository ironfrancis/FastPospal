# 银豹云后台账号（用于逆向私有 Web API）
POSPAL_ACCOUNT=your_account
POSPAL_PASSWORD=your_password

# 远程 HTTP 部署（可选）
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# MCP_AUTH_TOKEN=随机长字符串，Cursor / OPC Feed 连接时在 headers 里带 Bearer

# 多 worker / 负载均衡时建议开启（FastMCP stateless 模式）
# FASTMCP_STATELESS_HTTP=true

# 经 Nginx 以公网域名暴露时必填（JSON 数组字符串，否则远端 Host 会 421）
# 例：萌萌书店生产
# FASTMCP_HTTP_ALLOWED_HOSTS=["mmsd.site"]

# 可选：银豹开放平台凭证（官方 Open API，需向银豹业务申请 appId/appKey）
# POSPAL_APP_ID=
# POSPAL_APP_KEY=
# POSPAL_OPENAPI_HOST=https://area-openapi.pospal.cn

# 本地紧急发布 deploy/push-image.sh（可选，仅本机 .env，勿提交）
# DEPLOY_HOST=your-host
# DEPLOY_USER=root
# REMOTE_DIR=/opt/FastPospal
